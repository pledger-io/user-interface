{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "Patch version bumps",
      "matchUpdateTypes": ["patch"]
    },
    {
      "description": "PrimeReact v11+ requires a commercial license; stay on v10",
      "matchPackageNames": ["primereact"],
      "allowedVersions": "<11.0.0"
    }
  ],
  "addLabels": ["dependencies"],
  "assignees": ["gjong"]
}
